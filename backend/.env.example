# PostgreSQL connection string (matches docker-compose.yml from earlier)
DATABASE_URL=postgresql://skillheat:skillheat_dev_pw@localhost:5432/skillheat

# Comma-separated CORS origins. Add your deployed frontend URL here later.
ALLOWED_ORIGINS=http://localhost:3000

# News API key — optional. We mostly use free RSS feeds, this is a fallback.
# Get one at https://newsapi.org/ (free tier: 100 req/day)
NEWS_API_KEY=

# How often the background news fetcher runs (seconds)
NEWS_FETCH_INTERVAL_SECONDS=300

# Set to "true" to use seeded mock data instead of fetching real RSS.
# Useful for offline dev or when you don't want to spam feeds.
USE_MOCK_DATA=true
